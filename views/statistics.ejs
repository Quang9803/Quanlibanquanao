<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Thống kê doanh thu</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    <h1>Thống kê doanh thu</h1>
    <a href="/admin/products">← Quay về quản lý sản phẩm</a> |
    <a href="/logout">Đăng xuất</a>

    <h2>Tổng quan</h2>
    <p>Tổng số đơn hàng: <strong><%= totalOrders %></strong></p>
    <p>Tổng doanh thu: <strong><%= totalRevenue.toLocaleString() %> VNĐ</strong></p>

    <h2>Chi tiết đơn hàng</h2>

    <% if (orders.length === 0) { %>
        <p>Chưa có đơn hàng nào.</p>
    <% } else { %>
        <% orders.forEach(order => { %>
            <div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 20px;">
                <p><strong>Mã đơn:</strong> <%= order.id %></p>
                <p><strong>Khách hàng:</strong> <%= order.user %></p>
                <p><strong>Thời gian đặt:</strong> <%= order.date %></p>

                <table border="1" cellpadding="5" cellspacing="0">
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Size</th>
                        <th>Số lượng</th>
                        <th>Đơn giá</th>
                        <th>Thành tiền</th>
                    </tr>
                    <% order.items.forEach(item => { %>
                        <tr>
                            <td><%= item.name %></td>
                            <td><%= item.size %></td>
                            <td><%= item.quantity %></td>
                            <td><%= item.price.toLocaleString() %></td>
                            <td><%= item.total.toLocaleString() %></td>
                        </tr>
                    <% }) %>
                </table>

                <p><strong>Tổng đơn:</strong> <%= order.subtotal.toLocaleString() %> VNĐ</p>
            </div>
        <% }) %>
    <% } %>
</body>
</html>
