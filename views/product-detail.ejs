<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title><%= product.name %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .container {
      width: 60%;
      margin: auto;
      text-align: center;
    }
    .product-img {
      width: 300px;
      height: auto;
      margin-bottom: 20px;
    }
    .price {
      color: #e53935;
      font-size: 24px;
      font-weight: bold;
    }
    .size-options {
      margin: 10px 0;
    }
    .size-options label {
      margin: 0 10px;
      font-weight: bold;
    }
    .actions button {
      margin: 10px;
      padding: 10px 20px;
      font-size: 16px;
      cursor: pointer;
    }
    .description {
      margin-top: 30px;
      text-align: left;
    }
  </style>
</head>
<body>
  <%- include('partials/header') %>

  <div class="container">
    <img src="<%= product.image || '/images/default.jpg' %>" alt="<%= product.name %>" class="product-img">

    <h2><%= product.name %></h2>
    <div class="price"><%= product.price.toLocaleString() %> VNĐ</div>

    <div class="actions">
      <!-- FORM thêm vào giỏ -->
      <form method="POST" action="/cart/add">
        <input type="hidden" name="productId" value="<%= product.id %>">

        <!-- Size chỉ còn ở đây -->
        <div class="size-options">
          <label><input type="radio" name="size" value="S" checked> S</label>
          <label><input type="radio" name="size" value="M"> M</label>
          <label><input type="radio" name="size" value="L"> L</label>
          <label><input type="radio" name="size" value="XL"> XL</label>
        </div>

        <button type="submit">🛒 Thêm vào giỏ</button>
      </form>

      <!-- FORM mua ngay -->
      <form method="POST" action="/checkout-now">
        <input type="hidden" name="productId" value="<%= product.id %>">
        <input type="hidden" name="quantity" value="1">
        <button type="submit">💳 Mua ngay</button>
      </form>
    </div>

    <div class="description">
      <h3>Mô tả sản phẩm</h3>
      <p><%= product.description || "Không có mô tả." %></p>
    </div>
  </div>
</body>
</html>
